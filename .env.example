# =============================================================================
# REQUIRED — the app will not start without these
# =============================================================================

# Supabase — from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
# On Vercel: set this to your production URL (e.g. https://yourdomain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# OPTIONAL — features degrade gracefully if missing
# =============================================================================

# Default locale (ar | en)
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# WhatsApp business number (with country code, no "+").
# Can also be set in /admin/settings → WhatsApp; the admin setting takes precedence.
NEXT_PUBLIC_WHATSAPP_NUMBER=201000000000

# -----------------------------------------------------------------------------
# PayMob (Egypt) — required only if paymob_enabled=true in /admin/settings
# Get these from your PayMob dashboard
# -----------------------------------------------------------------------------
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# -----------------------------------------------------------------------------
# Resend (transactional email)
# Sign up at resend.com → create an API key
# RESEND_FROM_EMAIL must be a verified domain in Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@yourdomain.com

# -----------------------------------------------------------------------------
# reCAPTCHA v3 secret key (form spam protection)
# Public site key goes in /admin/settings → Integrations
# Secret stays here (server-side only)
# -----------------------------------------------------------------------------
RECAPTCHA_SECRET_KEY=
